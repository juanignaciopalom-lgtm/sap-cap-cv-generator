{
  "xsappname": "cv-app",
  "tenant-mode": "dedicated",
  "scopes": [
    {
      "name": "$XSAPPNAME.admin",
      "description": "Admin scope for CV editor"
    }
  ],
  "role-templates": [
    {
      "name": "CVAdmin",
      "description": "CV Editor role",
      "scope-references": [
        "$XSAPPNAME.admin"
      ]
    }
  ],
  "oauth2-configuration": {
    "redirect-uris": [
      "https://*.cfapps.us10-001.hana.ondemand.com/login/callback",
      "https://*.cfapps.us10-001.hana.ondemand.com/**"
    ]
  },
  "attributes": []
}
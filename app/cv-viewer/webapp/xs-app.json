{
  "welcomeFile": "/index.html",
  "authenticationMethod": "route",
  "routes": [
    {
      "source": "^/api/public/(.*)$",
      "target": "/api/public/$1",
      "destination": "srv-api",
      "authenticationType": "none"
    },
    {
      "source": "^/api/admin/(.*)$",
      "target": "/api/admin/$1",
      "destination": "srv-api",
      "authenticationType": "xsuaa"
    },
    {
      "source": "^(.*)$",
      "target": "$1",
      "authenticationType": "none"
    }
  ]
}